# Copia questo file in `.env.local` e riempi i valori. `.env.local` NON va nel repo.

# --- IA Gemini (Step 1: sintesi del DNA dai documenti del Drive) ---
# Chiave GRATUITA su https://aistudio.google.com/apikey ("Create API key").
# Senza questa chiave il DNA usa il fallback euristico (l'app non si rompe).
GEMINI_API_KEY=
# Opzionale: modello. Default gemini-2.5-flash (free tier verificata).
# GEMINI_MODEL=gemini-2.5-flash

# --- Google Drive (lettura reale dei file del DNA, via service account) ---
# 1) JSON della chiave del service account, su UNA riga, tra apici singoli:
#    GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# 2) Condividere la cartella Drive (sola lettura) con l'email del service account.
GOOGLE_SERVICE_ACCOUNT_JSON=
DRIVE_BANDI_FOLDER_ID=

# --- Persistenza (futuro) ---
# Per ora la persistenza è in-memory (si azzera a freddo). Per persistenza cross-sessione
# provisionare un Postgres e ripristinare il layer drizzle (vedi lib/db/schema.ts e lib/store.ts).
DATABASE_URL=
