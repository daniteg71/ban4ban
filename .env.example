# --- Modalità dati ---
# "mock" usa i JSON statici in /lib/mock-data (default per sviluppo parallelo)
# "live" usa Drive + Gemini reali
DATA_MODE=mock

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro-latest
# Modello embedding per la similarità semantica del funnel (economico). Vedi lib/pipeline/embeddings.ts
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Google Drive ---
# Service account JSON con accesso in lettura alla cartella del DNA
GOOGLE_SERVICE_ACCOUNT_JSON=
# ID della cartella radice Drive che contiene Formulario / Bilanci / Visura / CV / Bandi
DRIVE_ROOT_FOLDER_ID=
# Cartella bandi di riferimento (condivisa dal team):
# https://drive.google.com/drive/folders/1HFXiNjjnrnsNeaMRBDH-vGao-XepH_GE
DRIVE_BANDI_FOLDER_ID=1HFXiNjjnrnsNeaMRBDH-vGao-XepH_GE

# --- Cache DNA ---
# Durata cache del DNA in ms (default 600000 = 10 min). Vedi lib/dna-cache.ts
DNA_CACHE_TTL_MS=600000

# --- Scraping bandi online ---
# Eventuali endpoint/API dei portali appalti usati da lib/scraper.ts (live mode)
SCRAPER_PORTALI=
